# Labid Health — client environment (Vite). Copy to .env and fill in.
# Only VITE_-prefixed vars reach the browser; never put server secrets here.

# --- Backend (required) ---
# Leave both blank to run in offline dev mode (local login + seeded demo data).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Analytics (optional, Phase 6.2) ---
# Product analytics. Dormant until VITE_POSTHOG_KEY is set — no SDK is even
# loaded without it. Events are strictly non-PII (roles, counts, durations).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Error monitoring (Sentry). Dormant until the DSN is set.
VITE_SENTRY_DSN=

# --- Server-side secrets (NOT here) ---
# Edge Function secrets live in the Supabase dashboard / `supabase secrets set`,
# never in this file: AI_PROVIDER, GROQ_API_KEY, ANTHROPIC_API_KEY,
# TERMII_API_KEY, TERMII_SENDER_ID.
